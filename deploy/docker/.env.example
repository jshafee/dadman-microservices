# Copy this file to .env and set local values (no real secrets)

# SQL Server
MSSQL_SA_PASSWORD=ChangeMe_StrongPassword
SA_PASSWORD=ChangeMe_StrongPassword

# RabbitMQ
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=ChangeMe_StrongPassword

# Seq
SEQ_PASSWORD=ChangeMe_StrongPassword

# Auth (Gateway + Services)
AUTH_ISSUER=https://auth.local
AUTH_AUDIENCE=dadman-api
AUTH_SIGNING_KEY=__set_a_dev_key__

# Ordering -> Catalog service token (catalog.read)
CATALOG_SERVICE_TOKEN=__set_via_devjwt__

# Grafana
GRAFANA_ADMIN_PASSWORD=ChangeMe_StrongPassword

# Redis (Gateway distributed output cache)
REDIS_CONNECTIONSTRING=redis:6379

# Platform databases
ConnectionStrings__RegistryDb=Server=sqlserver,1433;Database=RegistryDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__IamDb=Server=sqlserver,1433;Database=IamDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__OrgDb=Server=sqlserver,1433;Database=OrgDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__DocumentDb=Server=sqlserver,1433;Database=DocumentDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__WorkflowDb=Server=sqlserver,1433;Database=WorkflowDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__AuditDb=Server=sqlserver,1433;Database=AuditDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true
ConnectionStrings__NotificationDb=Server=sqlserver,1433;Database=NotificationDb;User Id=sa;Password=ChangeMe_StrongPassword;TrustServerCertificate=true

# MinIO (optional local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
