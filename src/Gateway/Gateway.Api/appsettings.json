{
  "ReverseProxy": {
    "Routes": {
      "catalog-read-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}",
          "Methods": [
            "GET",
            "HEAD"
          ]
        },
        "AuthorizationPolicy": "catalog.read",
        "RateLimiterPolicy": "fixed",
        "OutputCachePolicy": "catalog-get"
      },
      "catalog-write-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "AuthorizationPolicy": "catalog.write",
        "RateLimiterPolicy": "write"
      },
      "ordering-read-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/ordering/{**catch-all}",
          "Methods": [
            "GET",
            "HEAD"
          ]
        },
        "AuthorizationPolicy": "ordering.read",
        "RateLimiterPolicy": "fixed"
      },
      "ordering-write-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/ordering/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "AuthorizationPolicy": "ordering.write",
        "RateLimiterPolicy": "write"
      },
      "platform-registry-route": {
        "ClusterId": "platform-registry-cluster",
        "Match": {
          "Path": "/api/platform-registry/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "iam-token-exchange-route": {
        "ClusterId": "iam-cluster",
        "Order": -10,
        "Match": {
          "Path": "/api/iam/v1/tokens:exchange",
          "Methods": [
            "POST"
          ]
        }
      },
      "iam-route": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "org-route": {
        "ClusterId": "org-cluster",
        "Match": {
          "Path": "/api/org/{**catch-all}"
        }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/api/docs/{**catch-all}"
        }
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "Match": {
          "Path": "/api/workflow/{**catch-all}"
        }
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": {
          "Path": "/api/audit/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notify/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "ordering": {
            "Address": "http://localhost:5102"
          }
        }
      },
      "platform-registry-cluster": {
        "Destinations": {
          "registry": {
            "Address": "http://localhost:5201"
          }
        }
      },
      "iam-cluster": {
        "Destinations": {
          "iam": {
            "Address": "http://localhost:5202"
          }
        }
      },
      "org-cluster": {
        "Destinations": {
          "org": {
            "Address": "http://localhost:5203"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "document": {
            "Address": "http://localhost:5204"
          }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow": {
            "Address": "http://localhost:5205"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit": {
            "Address": "http://localhost:5206"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:5207"
          }
        }
      }
    }
  },
  "Auth": {
    "Issuer": "https://auth.local",
    "Audience": "dadman-api",
    "SigningKey": "__SET_VIA_ENVIRONMENT__"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341",
    "ApiKey": "__OPTIONAL_SET_VIA_ENVIRONMENT__"
  }
}
